#

INSTALL_PATH=$(pwd)
LOG=$INSTALL_PATH/dwm_setup.log
rm $LOG > /dev/null 2>&1

clear

echo -ne "
   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—
   в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қ  в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
      в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ      в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘
   в–Ҳв–Ҳ в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•—      в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ в–Ҳв–Ҳв•‘      в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘
   в•ҡв–Ҳв–Ҳв–Ҳв•”в•қ    в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•—     в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
    в•ҡв•җв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•қ   в•ҡв•җв•қ     в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қ
"
echo ""
echo " Jax|Tech Setup Script will launch in 5 seconds..."

sleep 5

clear

##################################################################################################
#################################### INSTALL BASE APPS ###########################################
##################################################################################################

sudo pacman -Syu fish eza fastfetch git vim neovim gcc make base-devel pkgconf xorg xorg-xinit feh gxmessage sxiv python-pywal terminus-font ttf-mononoki-nerd noto-fonts-emoji \
lightdm lightdm-gtk-greeter openssh firefox qutebrowser mousepad figlet sxhkd slock dunst
sleep 10

clear

cp -r $INSTALL_PATH/src/lukesmithxyz/dwm ~/.config/dwm 2>&1 | tee -a $LOG
###git clone https://github.com/lukesmithxyz/dwm ~/dwm
cd ~/.config/dwm
echo "Compiling dwm - Dynamic Window Manager"
sudo make install
echo "Compiling dwm - Complete"
sleep 10

clear

cp -r $INSTALL_PATH/src/lukesmithxyz/dmenu ~/.config/dmenu 2>&1 | tee -a $LOG
###git clone https://github.com/lukesmithxyz/dmenu ~/dmenu
cd ~/.config/dmenu
echo "Compiling dmenu - Dynamic Menu"
sudo make install
echo "Compiling dmenu - Complete"
sleep 10

clear

cp -r $INSTALL_PATH/src/lukesmithxyz/st ~/.config/st 2>&1 | tee -a $LOG
###git clone https://github.com/lukesmithxyz/st ~/st
cd ~/.config/st
echo "Compiling st - Simple Terminal"
sudo make install
echo "Compiling st - Complete"
sleep 10

clear

cp -r $INSTALL_PATH/src/lukesmithxyz/dwmblocks ~/.config/dwmblocks 2>&1 | tee -a $LOG
###git clone https://github.com/lukesmithxyz/dwmblocks ~/dwmblocks
cd ~/.config/dwmblocks
echo "Compiling dwmblocks - Modular status bar"
make && sudo make install
echo "Compiling dwmblocks - Complete"
sleep 10

clear

cp -r $INSTALL_PATH/src/lukesmithxyz/dotfiles/.config/* ~/.config/ 2>&1 | tee -a $LOG
cp -r $INSTALL_PATH/src/lukesmithxyz/dotfiles/.local/* ~/.local/ 2>&1 | tee -a $LOG
cp -r $INSTALL_PATH/src/lukesmithxyz/dotfiles/.gitmodules ~/ 2>&1 | tee -a $LOG
cp -r $INSTALL_PATH/src/lukesmithxyz/dotfiles/.gtkrc-2.0 ~/ 2>&1 | tee -a $LOG
cp -r $INSTALL_PATH/src/lukesmithxyz/dotfiles/.xprofile ~/ 2>&1 | tee -a $LOG
cp -r $INSTALL_PATH/src/lukesmithxyz/dotfiles/.zprofile ~/ 2>&1 | tee -a $LOG
echo "Dotfiles Copy Complete"
sleep 10

clear

echo ""
echo "Please enter sudo password if requested..."
echo ""
sleep 5

##### xsessions -- Make sure xsessions directory exists and add dwm.desktop file
##### This file allows users to select DWM as a session option when logging into their system through a display manager.
# [ ! -d /usr/share/xsessions ] && sudo mkdir -p /usr/share/xsessions 2>&1 | tee -a $LOG
# sudo cp $INSTALL_PATH/configs/dwm.desktop /usr/share/xsessions/ 2>&1 | tee -a $LOG

##### lightdm -- Enable and start lightdm
echo "Enabling and starting lightdm..."
sleep 5
sudo systemctl enable lightdm
sudo systemctl start lightdm
sleep 5

##### openssh -- Enable and start openssh
echo "Enabling and starting openssh..."
sleep 5
sudo systemctl enable sshd
sudo systemctl start sshd
sudo ufw allow ssh
sleep 5

#########################################################################################
#################################### SETUP COMPLETE #####################################
#########################################################################################
clear
echo ""
read -p "Setup is Complete - Reboot the Machine NOW (y/n)? "
if [ "$REPLY" = "y" ]; then

  echo "" 2>&1 | tee -a $LOG
  echo Rebooting Now... 2>&1 | tee -a $LOG
  sudo reboot 2>&1 | tee -a $LOG
  sleep 2
  
else
  exit
fi

exit
